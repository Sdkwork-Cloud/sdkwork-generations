{
  "name": "@sdkwork/generations-pc-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Unified generation history and task result provenance.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts",
      "default": "./src/react.ts"
    },
    "./generation": {
      "types": "./src/generation.ts",
      "import": "./src/generation.ts",
      "default": "./src/generation.ts"
    },
    "./generation-asset-config": {
      "types": "./src/generation-asset-config.ts",
      "import": "./src/generation-asset-config.ts",
      "default": "./src/generation-asset-config.ts"
    },
    "./generation-history": {
      "types": "./src/generation-history.ts",
      "import": "./src/generation-history.ts",
      "default": "./src/generation-history.ts"
    },
    "./generation-service": {
      "types": "./src/generation-service.ts",
      "import": "./src/generation-service.ts",
      "default": "./src/generation-service.ts"
    },
    "./generation-playground-workspace": {
      "types": "./src/generationPlaygroundWorkspace.ts",
      "import": "./src/generationPlaygroundWorkspace.ts",
      "default": "./src/generationPlaygroundWorkspace.ts"
    },
    "./generation-panel": {
      "types": "./src/generationPanel.ts",
      "import": "./src/generationPanel.ts",
      "default": "./src/generationPanel.ts"
    },
    "./generation-history-ui": {
      "types": "./src/generationHistoryUi.ts",
      "import": "./src/generationHistoryUi.ts",
      "default": "./src/generationHistoryUi.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sdkwork/assets-pc-commons": "workspace:*",
    "@sdkwork/audio-pc-generation": "workspace:*",
    "@sdkwork/generations-pc-asset-config": "workspace:*",
    "@sdkwork/generations-pc-studio": "workspace:*",
    "@sdkwork/image-pc-generation": "workspace:*",
    "@sdkwork/models-pc-picker": "workspace:*",
    "@sdkwork/music-pc-generation": "workspace:*",
    "@sdkwork/ui-pc-react": "workspace:*",
    "@sdkwork/video-pc-generation": "workspace:*",
    "lucide-react": "catalog:",
    "react-i18next": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "jsdom": "catalog:",
    "vitest": "catalog:"
  },
  "sdkwork": {
    "workspace": "sdkwork-generations-pc",
    "architecture": "pc-react",
    "surface": "app",
    "domain": "intelligence",
    "capability": "workspace",
    "status": "ready"
  }
}
