{
  "name": "@sdkwork/generations-pc-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "SDKWork generations playground shell UI with host-injected runtime.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts",
      "default": "./src/react.ts"
    },
    "./playground-types": {
      "types": "./src/playground-types.ts",
      "import": "./src/playground-types.ts",
      "default": "./src/playground-types.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sdkwork/assets-pc-assets": "workspace:*",
    "@sdkwork/generations-pc-workspace": "workspace:*",
    "@sdkwork/image-pc-generation": "workspace:*",
    "@sdkwork/video-pc-generation": "workspace:*",
    "@sdkwork/music-pc-generation": "workspace:*",
    "@sdkwork/audio-pc-generation": "workspace:*",
    "@sdkwork/models-pc-picker": "workspace:*",
    "hast-util-sanitize": "^5.0.2",
    "style-to-js": "^1.1.21",
    "lucide-react": "catalog:",
    "react-markdown": "10.1.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0",
    "react-i18next": ">=15.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  },
  "sdkwork": {
    "workspace": "sdkwork-generations-pc",
    "architecture": "pc-react",
    "surface": "app",
    "domain": "intelligence",
    "capability": "playground",
    "status": "ready"
  }
}
