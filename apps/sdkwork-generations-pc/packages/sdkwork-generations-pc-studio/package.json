{
  "name": "@sdkwork/generations-pc-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Shared borderless generation studio UI primitives for PC playground surfaces.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "import": "./src/react.ts",
      "default": "./src/react.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sdkwork/utils": "workspace:*",
    "lucide-react": "catalog:",
    "react-i18next": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sdkwork": {
    "workspace": "sdkwork-generations-pc",
    "architecture": "pc-react",
    "domain": "intelligence",
    "capability": "generation-studio",
    "status": "ready"
  }
